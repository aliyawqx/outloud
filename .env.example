# Postgres connection string.
# On Railway/Render: add a Postgres plugin/instance and reference its connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/outloud

# Email notifications for early-access signups (Resend).
# Create a free key at https://resend.com (free tier sends to your own account email
# without domain verification). Leave empty to disable email and just store signups.
RESEND_API_KEY=
# Where signup notifications are sent (defaults to zhanabayaliya@gmail.com).
NOTIFY_EMAIL=zhanabayaliya@gmail.com
