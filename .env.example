# Postgres connection string.
# On Railway/Render: add a Postgres plugin/instance and reference its connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/outloud

# Secret for signing session cookies (custom email+password auth).
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# Email notifications for early-access signups (Resend).
# Create a free key at https://resend.com (free tier sends to your own account email
# without domain verification). Leave empty to disable email and just store signups.
RESEND_API_KEY=
# Where signup notifications are sent (defaults to zhanabayaliya@gmail.com).
NOTIFY_EMAIL=zhanabayaliya@gmail.com

# Verification-code email transport. Gmail SMTP delivers to ANY address with no
# domain needed (good for low volume): set both to your gmail + an app password
# (https://myaccount.google.com/apppasswords, needs 2FA). If unset, falls back to
# Resend (RESEND_API_KEY), which only delivers to the account owner until a domain
# is verified. Optional VERIFY_EMAIL_FROM overrides the "from" address.
GMAIL_USER=
GMAIL_APP_PASSWORD=
VERIFY_EMAIL_FROM=

# Polar (Merchant of Record) — powers checkout + subscription management. Create
# products in Polar, then paste the org access token (secret) and the product IDs.
# POLAR_SERVER is "production" or "sandbox". POLAR_WEBHOOK_SECRET comes from the
# webhook endpoint you add in Polar (Settings -> Webhooks).
POLAR_ACCESS_TOKEN=
POLAR_SERVER=production
POLAR_PRO_PRODUCT_ID=
POLAR_STARTER_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
# One-time credit-pack products (top-ups). Create them in Polar and paste the ids.
POLAR_PACK_100K_PRODUCT_ID=
POLAR_PACK_500K_PRODUCT_ID=
POLAR_PACK_1M_PRODUCT_ID=
# NOTE: signups get a 7-day card-free trial (10k credits) automatically, then drop to
# 0 and hit the upgrade paywall — no card gate. Use Polar plan products WITHOUT a trial
# period so a chosen plan charges immediately.

# Anthropic Claude API — powers voice capture + post generation (MVP).
ANTHROPIC_API_KEY=
# Optional model override. Default: claude-sonnet-4-6.
# Cheaper/lower-nuance: claude-haiku-4-5 · Best quality: claude-opus-4-8
ANTHROPIC_MODEL=

# Tavily web research (optional) — gives the post writer a model-chosen tool to
# look up current facts as invisible background knowledge. Unset = feature off,
# generation works exactly as before. Get a key at https://app.tavily.com
TAVILY_API_KEY=

# ── Images on post drafts ──────────────────────────────────────────────────
# Vercel Blob storage — every attached image (AI, stock, or upload) is copied here
# and the public URL is stored on the draft. Auto-provisioned with a Vercel Blob
# store; token from the Vercel dashboard (Storage → your Blob store).
BLOB_READ_WRITE_TOKEN=
# Unsplash stock photo search (https://unsplash.com/developers). Searching is free;
# we charge credits only when the user picks a photo.
UNSPLASH_ACCESS_KEY=
# kie.ai for AI image generation via Flux (https://kie.ai/api-key).
KIE_API_KEY=
# Optional: override the kie.ai image model (default: flux-2/pro-text-to-image).
KIE_IMAGE_MODEL=

# ── X (Twitter) API OAuth 2.0 ──────────────────────────────────────────────
# From the X Developer Portal → your app → "User authentication settings".
X_CLIENT_ID=
X_CLIENT_SECRET=
# Must EXACTLY match a Callback URI registered in the portal.
X_REDIRECT_URI=http://localhost:3000/api/x/callback
# 32 random bytes, base64. Encrypts X tokens at rest. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
X_TOKEN_ENC_KEY=
# Set to 1 to request the media.write scope so images can be attached to tweets.
# NOTE: media.write is only grantable on a PAID X API tier (Basic+). On the Free
# tier, requesting it makes X consent fail ("couldn't give access to the App"), so
# leave this unset until the X app is on a paid tier. When unset, X posts go out
# text-only (images still publish to Threads). After enabling, users reconnect X once.
X_REQUEST_MEDIA_SCOPE=

# ── Threads (Meta) API ─────────────────────────────────────────────────────
# From the Meta App Dashboard (App ID + App Secret). Keep the secret private.
THREADS_APP_ID=
THREADS_APP_SECRET=
# Must EXACTLY match a redirect URI registered for the Threads use case.
THREADS_REDIRECT_URI=http://localhost:3000/api/threads/callback
# 32 random bytes, base64. Encrypts Threads tokens at rest (separate from X).
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
THREADS_TOKEN_ENC_KEY=
# Topic-search (keyword_search) permission gate. Set to 1 only after Meta approves
# threads_keyword_search for the app, then reconnect Threads. Leave empty otherwise.
THREADS_KEYWORD_SEARCH=

# ── LinkedIn OAuth (Share on LinkedIn, Default Tier — personal profile only) ──
# Redirect URI must EXACTLY match one registered on the app's Auth tab.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback
# Versioned Posts API month (YYYYMM). Bump ~yearly; one line, see lib/linkedin/config.ts.
LINKEDIN_API_VERSION=202506
# 32 random bytes, base64. Encrypts LinkedIn tokens at rest (separate key per provider).
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
LINKEDIN_TOKEN_ENC_KEY=
# Set to 1 to skip the /rest/posts probe and always use /v2/ugcPosts.
LINKEDIN_FORCE_UGC=
